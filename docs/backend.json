{
  "entities": {
    "ServiceBusiness": {
      "title": "ServiceBusiness",
      "description": "Represents a white-label field service management business (tenant).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "industry": { 
          "type": "string", 
          "enum": ["plumbing", "electrical", "hvac", "landscaping", "auto_repair", "cleaning", "general_contracting"],
          "description": "The primary industry of the business."
        },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "stripeAccountId": { "type": "string" }
      },
      "required": ["id", "name", "industry", "contactEmail", "contactPhone", "address"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Represents a customer of a specific service business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceBusinessId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "serviceAddress": { "type": "string" }
      },
      "required": ["id", "serviceBusinessId", "firstName", "lastName", "email", "phone"]
    },
    "Technician": {
      "title": "Technician",
      "description": "Represents a field technician employed by a service business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceBusinessId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isDispatcher": { "type": "boolean" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "serviceBusinessId", "firstName", "lastName", "email", "isActive"]
    },
    "Job": {
      "title": "Job",
      "description": "Represents a specific service job to be performed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceBusinessId": { "type": "string" },
        "customerId": { "type": "string" },
        "technicianId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "source": { 
          "type": "string", 
          "enum": ["manual", "whatsapp", "telegram", "sms", "web_portal"],
          "description": "Where the job request originated from."
        },
        "status": { "type": "string", "enum": ["scheduled", "in_progress", "completed", "cancelled"] },
        "scheduledStartDateTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "workSummary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "serviceBusinessId", "customerId", "technicianId", "title", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/service_businesses/{serviceBusinessId}": {
      "schema": { "$ref": "#/backend/entities/ServiceBusiness" },
      "description": "Root tenant documents defining business boundaries."
    },
    "/service_businesses/{serviceBusinessId}/customers/{customerId}": {
      "schema": { "$ref": "#/backend/entities/Customer" },
      "description": "Customers scoped to a specific business ID."
    },
    "/service_businesses/{serviceBusinessId}/technicians/{technicianId}": {
      "schema": { "$ref": "#/backend/entities/Technician" },
      "description": "Technicians scoped to a specific business ID."
    },
    "/service_businesses/{serviceBusinessId}/jobs/{jobId}": {
      "schema": { "$ref": "#/backend/entities/Job" },
      "description": "Jobs scoped to business and assigned technician."
    }
  }
}
